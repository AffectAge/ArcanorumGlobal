  },
  "dependencies": {
    "@arcanorum/shared": "0.1.0",
    "@prisma/client": "^6.4.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.21.2",
    "geojson-vt": "^4.0.2",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "svg-path-properties": "^2.0.1",
    "vt-pbf": "^3.1.3",
    "ws": "^8.18.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/geojson": "^7946.0.16",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.13.1",
    "@types/ws": "^8.5.14",
    "prisma": "^6.4.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
