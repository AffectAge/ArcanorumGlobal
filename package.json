{
  "name": "arcanorum-monorepo",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "node scripts/fix-esbuild.cjs",
    "dev": "concurrently \"npm run dev -w @arcanorum/server\" \"npm run dev -w @arcanorum/client\"",
    "build": "npm run build -ws",
    "lint": "npm run lint -ws",
    "typecheck": "npm run typecheck -ws"
  },
  "devDependencies": {
    "@esbuild/win32-x64": "0.25.12",
    "concurrently": "^9.2.1"
  }
}
